{
  "name": "wpd-qa",
  "version": "0.1.0",
  "description": "Wheat Pest & Disease Question Answering System",
  "private": true,
  "scripts": {
    "install:all": "pnpm install && cd frontend && pnpm install && cd ../admin && pnpm install && cd ../backend && pnpm install",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\" \"pnpm dev:admin\"",
    "dev:frontend": "pnpm --filter @wpd/frontend run dev",
    "dev:admin": "pnpm --filter @wpd/admin run dev",
    "dev:backend": "pnpm --filter @wpd/backend run dev",
    "build": "pnpm build:backend && pnpm build:frontend && pnpm build:admin",
    "build:frontend": "pnpm --filter @wpd/frontend run build",
    "build:admin": "pnpm --filter @wpd/admin run build",
    "build:backend": "pnpm --filter @wpd/backend run build",
    "start": "concurrently \"pnpm start:backend\" \"pnpm start:frontend\" \"pnpm start:admin\"",
    "start:frontend": "pnpm --filter @wpd/frontend run start",
    "start:admin": "pnpm --filter @wpd/admin run start",
    "start:backend": "pnpm --filter @wpd/backend run start",
    "db:generate": "pnpm --filter @wpd/backend run db:generate",
    "db:migrate": "pnpm --filter @wpd/backend run db:migrate",
    "db:push": "pnpm --filter @wpd/backend run db:push",
    "db:studio": "pnpm --filter @wpd/backend run db:studio",
    "lint": "eslint frontend/src admin/src backend/src --ext .ts,.tsx",
    "lint:fix": "eslint frontend/src admin/src backend/src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules frontend/node_modules admin/node_modules backend/node_modules && rimraf pnpm-lock.yaml frontend/pnpm-lock.yaml admin/pnpm-lock.yaml backend/pnpm-lock.yaml",
    "reinstall": "pnpm clean && pnpm install:all"
  },
  "keywords": [
    "wheat",
    "disease",
    "QA",
    "AI",
    "RAG"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
